# TKADS v4 — 环境配置
# 复制此文件为 .env 并填入真实值

# GitHub 个人访问令牌（用于上传技能到仓库）
# 需要 repo 权限，在 https://github.com/settings/tokens 创建
GITHUB_TOKEN=your_github_token_here

# PostgreSQL 数据库连接（可选，用于 Dashboard）
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/hanmac

# Hermes Agent 家目录（自动检测，通常不用设置）
HERMES_HOME=

# TikTok Shop 信息
SHOP_REGION=MY
SHOP_LANG=en

# 可选：IMA 知识库（用于笔记沉淀）
IMA_URL=
IMA_TOKEN=
